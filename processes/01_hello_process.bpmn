<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  id="Definitions_01"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="hello-process" name="01 - Hello Process" isExecutable="true">

    <!-- Evenement de debut -->
    <bpmn:startEvent id="StartEvent_1" name="Debut">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Service Task : log hello -->
    <bpmn:serviceTask id="Task_Hello" name="Log Hello World">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="log-hello" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Evenement de fin -->
    <bpmn:endEvent id="EndEvent_1" name="Fin">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Hello" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Hello" targetRef="EndEvent_1" />

  </bpmn:process>

</bpmn:definitions>
